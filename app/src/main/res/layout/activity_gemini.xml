<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0E2233">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:background="#0A1520">

        <Button
            android:id="@+id/geminiBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Nazaj"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:textSize="15sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🤖 AI Planinski Asistent"
            android:textColor="#B8C5D1"
            android:textSize="15sp"
            android:gravity="center" />

        <View android:layout_width="80dp" android:layout_height="1dp" />

    </LinearLayout>

    <!-- Main scrollable content -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Equipment header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎒 Priporočena oprema"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Odkljukaj ko spakiraš"
                android:textColor="#888888"
                android:textSize="13sp" />

            <!-- Loading -->
            <ProgressBar
                android:id="@+id/geminiLoading"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:indeterminateTint="#6BB5FF" />

            <!-- Equipment items -->
            <LinearLayout
                android:id="@+id/equipmentContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:background="#112840"
                android:padding="8dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="20dp"
                android:background="#20FFFFFF" />

            <!-- Chat header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Pogovor z AI"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Postavi vprašanje o poti ali opremi"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="12dp" />

            <!-- Chat messages -->
            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </ScrollView>

    <!-- Input bar (fixed at bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:background="#0A1520">

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Vprašaj AI asistenta..."

            android:textColor="#FFFFFF"
            android:backgroundTint="#1A3A52"
            android:padding="12dp"
            android:inputType="textCapSentences|textMultiLine"
            android:maxLines="3" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:backgroundTint="#FF9A7A"
            android:text="↑"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:padding="0dp" />

    </LinearLayout>

</LinearLayout>