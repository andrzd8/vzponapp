<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/onboardingScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboarding"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center|bottom"
        android:text="@string/onboarding_title"
        android:textColor="@color/text_primary"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="@string/onboarding_subtitle"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="18dp"
        android:background="@color/input_background"
        android:hint="@string/onboarding_name_hint"
        android:padding="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint" />

    <LinearLayout
        android:id="@+id/experienceGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:orientation="vertical"
        android:visibility="gone">

        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/expHiker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@color/selection_background"
                android:buttonTint="@color/accent_peach"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/exp_hiker"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/expMountaineer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@color/selection_background"
                android:buttonTint="@color/accent_peach"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/exp_mountaineer"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/expAlpinist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/selection_background"
                android:buttonTint="@color/accent_peach"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:text="@string/exp_alpinist"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

        </RadioGroup>

    </LinearLayout>

    <Button
        android:id="@+id/nextButton"
        android:layout_width="140dp"
        android:layout_height="54dp"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/primary_orange"
        android:text="@string/onboarding_next"
        android:textColor="@color/text_primary" />

    <TextView
        android:id="@+id/dotsText"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:gravity="center"
        android:text="@string/onboarding_dots_1"
        android:textColor="@color/text_primary"
        android:textSize="24sp" />

</LinearLayout>