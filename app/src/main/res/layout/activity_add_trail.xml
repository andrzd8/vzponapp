<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dodaj pot"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ime poti"
        android:inputType="text"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/descriptionInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Opis"
        android:inputType="textMultiLine"
        android:minLines="2"
        android:layout_marginBottom="20dp" />

    <Button
        android:id="@+id/pickGpxButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Izberi GPX datoteko"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/gpxStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ni izbrane datoteke"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/statsPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/saveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Shrani pot" />

</LinearLayout>