<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboarding"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:text="@string/home_header"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/trailRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:overScrollMode="never" />

    <!-- Bottom nav — samo ikone + dot indikator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#252525"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Poti (aktivno) -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/navHomeIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_home"
                android:textSize="22sp" />

            <View
                android:id="@+id/navHomeDot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="#FF6B35" />

        </LinearLayout>

        <!-- Zemljevid (neaktivno) -->
        <LinearLayout
            android:id="@+id/navMap"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/navMapIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_map"
                android:textSize="22sp"
                android:alpha="0.4" />

            <View
                android:id="@+id/navMapDot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <!-- Profil (neaktivno) -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/navProfileIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_profile"
                android:textSize="22sp"
                android:alpha="0.4" />

            <View
                android:id="@+id/navProfileDot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent" />

        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/filterButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/colorSecondary"
        android:text="@string/filter_all"
        android:textColor="#FFFFFF" />

</LinearLayout>